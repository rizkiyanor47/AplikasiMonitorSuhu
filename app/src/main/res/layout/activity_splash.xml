<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <View
        android:id="@+id/white_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginVertical="80dp"
        android:background="@drawable/bg_white_card"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/logo_placeholder"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="64dp"
        android:src="@drawable/ic_placeholder_rounded"
        app:layout_constraintEnd_toEndOf="@id/white_card"
        app:layout_constraintStart_toStartOf="@id/white_card"
        app:layout_constraintTop_toTopOf="@id/white_card" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="TofuMonitor"
        android:textColor="@color/tofu_orange"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="@id/white_card"
        app:layout_constraintStart_toStartOf="@id/white_card"
        app:layout_constraintTop_toBottomOf="@id/logo_placeholder" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Real-time Industrial\nTemperature Monitoring"
        android:textColor="@color/tofu_orange"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="@id/white_card"
        app:layout_constraintStart_toStartOf="@id/white_card"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <ProgressBar
        android:id="@+id/progress_bar"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:indeterminateTint="@color/white"
        android:indeterminateTintMode="src_in"
        app:layout_constraintBottom_toTopOf="@+id/ll_politala"
        app:layout_constraintEnd_toEndOf="@id/white_card"
        app:layout_constraintStart_toStartOf="@id/white_card"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle" />

    <LinearLayout
        android:id="@+id/ll_politala"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="@id/white_card"
        app:layout_constraintEnd_toEndOf="@id/white_card"
        app:layout_constraintStart_toStartOf="@id/white_card">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_report_image"
            app:tint="@color/text_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="POLITALA"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_footer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:text="Suhu Tahu Goreng IoT v1.0.0\nPOLITALA"
        android:textColor="@color/tofu_brown"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>